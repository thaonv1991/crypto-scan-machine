# Database
DATABASE_URL=postgresql+asyncpg://cryptoscan:cryptoscan_pass@localhost:5432/cryptoscan
DATABASE_URL_SYNC=postgresql://cryptoscan:cryptoscan_pass@localhost:5432/cryptoscan

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=cryptoscan

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI APIs (free tiers)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Etherscan
ETHERSCAN_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
API_RATE_LIMIT=100

# Production (docker-compose.prod.yml)
POSTGRES_PASSWORD=cryptoscan_pass
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# PostgreSQL Tuning (adjust based on server RAM)
# 8GB server: shared_buffers=2GB, effective_cache_size=6GB, work_mem=64MB, maintenance_work_mem=512MB
# 4GB server: shared_buffers=1GB, effective_cache_size=3GB, work_mem=32MB, maintenance_work_mem=256MB
# 2GB server (default): shared_buffers=512MB, effective_cache_size=1536MB, work_mem=32MB, maintenance_work_mem=256MB
# PG_SHARED_BUFFERS=512MB
# PG_EFFECTIVE_CACHE_SIZE=1536MB
# PG_WORK_MEM=32MB
# PG_MAINTENANCE_WORK_MEM=256MB
